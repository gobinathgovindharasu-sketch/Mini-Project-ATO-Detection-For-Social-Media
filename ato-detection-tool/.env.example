# ============================
# ATO Detection Tool — Environment Variables
# ============================
# Copy this file to .env and update values for production.

# --- PostgreSQL ---
POSTGRES_PASSWORD=ato_secret_2025

# --- Backend ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=super-secret-change-in-production

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# Database URL (set by docker-compose, override for local dev)
DATABASE_URL=sqlite:///./ato_detection.db

# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Webhook URL for high-risk alerts (optional)
WEBHOOK_URL=

# Risk score threshold for alerts (0.0 to 1.0)
RISK_THRESHOLD=0.8

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
